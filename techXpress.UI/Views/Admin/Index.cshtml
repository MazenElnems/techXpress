@model List<(techXpress.DataAccess.Entities.User User, IList<string> Roles)>

@{
    ViewData["Title"] = "Admin Dashboard - User Management";
}

<h2>User Management</h2>

<form asp-action="BulkDeleteUsers" method="post">
    <div class="mb-3">
        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete the selected users?');">Delete Selected</button>
        <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-success">Create New User</a>
    </div>

    <table id="usersTable" class="table table-striped">
        <thead>
            <tr>
                <th><input type="checkbox" id="selectAll" /></th>
                <th>UserName</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var userInfo in Model)
            {
                <tr>
                    <td><input type="checkbox" name="userIds" value="@userInfo.User.Id" /></td>
                    <td>@userInfo.User.UserName</td>
                    <td>@userInfo.User.Email</td>
                    <td>@string.Join(", ", userInfo.Roles)</td>
                    <td>
                        <a asp-action="EditUser" asp-route-id="@userInfo.User.Id" class="btn btn-primary btn-sm">Edit</a>
                        <a asp-action="DeleteUser" asp-route-id="@userInfo.User.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#usersTable').DataTable({
                "paging": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "lengthMenu": [5, 10, 25, 50],
                "pageLength": 5,
                "columnDefs": [
                    { "orderable": false, "targets": 0 } // Disable sorting on checkbox column
                ]
            });

            // Select all checkboxes
            $('#selectAll').on('click', function () {
                $('input[name="userIds"]').prop('checked', this.checked);
            });
        });
    </script>
}