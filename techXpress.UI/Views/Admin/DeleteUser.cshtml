@model techXpress.UI.ActionRequests.UpdateUserActionRequest

@{
	ViewData["Title"] = "Delete User";
}

<h2>Delete User</h2>

<div class="alert alert-danger" role="alert">
	<h4 class="alert-heading">Are you sure you want to delete this user?</h4>
	<p>This action cannot be undone.</p>
	<hr />
	<p><strong>Username:</strong> @Model.UserName</p>
	<p><strong>Email:</strong> @Model.Email</p>
	<p><strong>Phone Number:</strong> @Model.PhoneNumber</p>
	<p><strong>Role:</strong> @Model.Role</p>
</div>

<form asp-action="DeleteUser" asp-route-id="@Model.Id" method="post">
	<button type="submit" class="btn btn-danger">Delete</button>
	<a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>